# Copy to .env to override defaults.
#
# If MONGODB_URI is left unset, the server boots an in-memory MongoDB
# *replica set* automatically (no install needed) so that transactions work.
# Set this to point at a real MongoDB (must be a replica set for transactions).
# MONGODB_URI=mongodb://127.0.0.1:27017/test-qs-mern?replicaSet=rs0

PORT=3000
